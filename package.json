{
  "name": "birthday-whatsapp-bot",
  "version": "1.0.0",
  "description": "Personal WhatsApp birthday reminder service.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run build && npm test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "db:migrate": "node dist/cli/db-migrate.js",
    "db:migrate:dev": "tsx src/cli/db-migrate.ts",
    "whatsapp:list-groups": "tsx src/cli/list-groups.ts",
    "birthdays:check-today": "tsx src/cli/check-today.ts"
  },
  "keywords": [
    "whatsapp",
    "birthday",
    "bot"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/testing": "^11.1.24",
    "@types/node": "^20.11.30",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/sql.js": "^1.4.11",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.1",
    "baileys": "^7.0.0-rc13",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sql.js": "^1.14.1",
    "typeorm": "^0.3.28"
  }
}
